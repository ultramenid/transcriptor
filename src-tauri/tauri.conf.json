{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcriptor",
  "version": "0.3.1",
  "identifier": "com.transcriptor.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg1Mzk3RDQyOUJEMTc3MDMKUldRRGQ5R2JRbjA1aFJNMDU2eUphRDNRU05DYUdlYURXeU04bjc2dWZnU21uR1pzWGF4UDdQK20K",
      "endpoints": [
        "https://github.com/ultramenid/transcriptor/releases/latest/download/latest.json"
      ]
    }
  }
}
